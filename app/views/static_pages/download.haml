%h1 Download 
%ul
  %li
    全文
    %ul
      %li= link_to "HTML版 佛典", controller: 'static_pages', action: 'download_html'
      %li= link_to "純文字版 佛典", controller: 'static_pages', action: 'download_text'
      %li= link_to "DocuXml", controller: 'static_pages', action: 'download_docusky'
      %li
        =link_to "電子書", controller: 'static_pages', action: 'download_ebooks'
        (EPUP, PDF, DOCX, ODT)
  %li= link_to "校注", controller: 'static_pages', action: 'download_footnotes'
  %li= link_to_path '嘉興藏檢查表', 'download/check-list-J.csv'
  %li= link_to_path '全部作譯者列表', 'download/all-creators.json'
  %li= link_to '全部作譯者列表 (含別名)', '#all_creators2'
  %li= link_to '範圍選擇清單', { controller: 'static_pages', action: 'scope_selector' }
  %li= link_to '全部佛典 卷列表', '#all_works'

%h2#all_creators2 全部作譯者列表(含別名)
%p
  URL: 
  = link_to_url '/download/all-creators-with-alias.json'
%p 回傳 JSON 例：
%pre.ml-3
  :preserve
    {
      "num_found": 2185,
      "results": {
        "A000001": {
          "regular_name": "金總持",
          "aliases_all": [
            "金揔持",
            "寶輪大師",
            "明因妙善普濟法師"
          ]
        },
        "A000002": {
          "regular_name": "𧧌震",
          "aliases_all": [
            "仁山𧧌震",
            "仁山大師",
            "寂震",
            "華頂震",
            "仁叟"
          ]
        },
        ...
      }
    }

%h2#all_works 全部佛典 卷列表
%p
  URL: 
  = link_to_path nil, 'download/all-works.json'
%p 回傳 JSON 例：
%pre.ml-3
  :preserve
    [
      {
        "work": "Ba001",
        "title": "出版說明",
        "juans": [
          "1"
        ]
      },
      ...
      {
        "work": "T0001",
        "title": "長阿含經",
        "juans": [
          "1",
          "2",
          ...
          "22"
        ]
      },
      ...
    ]
